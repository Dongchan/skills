{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(git commit:*)",
      "Bash(git remote add:*)",
      "Bash(git add:*)",
      "Bash(unzip:*)",
      "Bash(xargs ls:*)",
      "Bash(codex:*)",
      "Bash(find:*)",
      "Bash(lsof:*)",
      "WebSearch",
      "WebFetch",
      "Bash",
      "Bash(npx create-next-app:*)",
      "Bash(npx shadcn@latest add:*)",
      "Bash(npx next build:*)",
      "Bash(node -e:*)",
      "Bash(git*)",
      "Bash(xargs:*)",
      "Bash(npx next dev)",
      "Bash(npx tsc:*)",
      "Bash(curl:*)",
      "Bash(kill:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Write(**)",
      "Read",
      "Search",
      "Write",
      "Edit",
      "MultiEdit",
      "CREATE"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(npm publish:*)",
      "Bash(eval:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/*credential*)",
      "Read(**/*secret*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); printf \"\\033[32m$(whoami)@$(hostname -s)\\033[0m:\\033[34m$(echo \"$input\" | jq -r '.workspace.current_dir')\\033[0m [$(echo \"$input\" | jq -r '.model.display_name')]\""
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "gws@gws-marketplace": true,
    "harness@harness-marketplace": true
  },
  "extraKnownMarketplaces": {
    "gws-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/gws"
      }
    },
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      },
      "autoUpdate": true
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
